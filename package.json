{
  "name": "@hacknock/lobster-wiki",
  "version": "0.1.0",
  "description": "Wiki/multi-page site extension for lobster.js — Markdown-driven, zero-config",
  "keywords": [
    "lobster",
    "markdown",
    "wiki",
    "multi-page",
    "static-site",
    "no-build",
    "zero-dependency",
    "css-first",
    "browser",
    "esm",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/lobster-wiki.js",
  "module": "./dist/lobster-wiki.js",
  "types": "./dist/lobster-wiki.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lobster-wiki.js",
      "types": "./dist/lobster-wiki.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:docs": "vite build && cp dist/lobster-wiki.js docs/lobster-wiki.js",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "packageManager": "pnpm@10.30.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
